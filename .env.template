# مفاتيح الوصول والرموز السرية للمشروع
# قم بنسخ هذا الملف وتسميته .env وتعبئة البيانات المطلوبة

# 1. مفتاح منصة بينانس سكوير (Binance Square OpenAPI Key)
BINANCE_SQUARE_API_KEY=your_binance_square_api_key_here

# 2. مفتاح الوصول لـ Groq Cloud API Key
GROQ_API_KEY=your_groq_api_key_here

# 3. اسم نموذج Groq المراد استخدامه (Groq Model Name)
GROQ_MODEL=llama-3.3-70b-versatile

# 4. إعدادات الجدولة في أوقات الذروة (Peak Hours Scheduler Settings)
# فارق التوقيت المحلي الخاص بك مقارنة بتوقيت UTC (مثال: 1 لتوقيت الجزائر/المغرب، 3 لتوقيت مكة المكرمة)
TIMEZONE_OFFSET=1

# أوقات الذروة المحددة للنشر (10 أوقات موزعة على مدار اليوم)
PEAK_HOURS=08:00,09:30,11:00,13:00,14:30,16:00,18:00,20:00,21:30,23:00

# تفعيل التباعد العشوائي لمنع الملاحظة التلقائية (True لتفعيله، False لإلغائه)
USE_JITTER=True

# أقصى تفاوت عشوائي بالثواني (مثال: 300 ثانية تعادل 5 دقائق كحد أقصى للحفاظ على دقة أوقات الذروة)
JITTER_MAX_SECONDS=300
