# مفاتيح الوصول والرموز السرية للمشروع
# قم بنسخ هذا الملف وتسميته .env وتعبئة البيانات المطلوبة

# 1. مفتاح منصة بينانس سكوير (Binance Square OpenAPI Key)
BINANCE_SQUARE_API_KEY=your_binance_square_api_key_here

# 2. مفتاح الوصول لـ Groq Cloud API Key
GROQ_API_KEY=your_groq_api_key_here

# 3. اسم نموذج Groq المراد استخدامه (Groq Model Name)
GROQ_MODEL=llama-3.3-70b-versatile

# 4. إعدادات جدولة الاستضافة (Hosting Scheduler Settings)
# نمط الجدولة: 'interval' (نشر دوري كل X ثانية) أو 'peak_hours' (نشر في ساعات محددة)
SCHEDULER_MODE=interval

# الفاصل الزمني بالثواني بين كل منشور (1800 ثانية تعادل 30 دقيقة تماماً للنشر كل نصف ساعة)
# يتم تفعيل هذا المتغير فقط عندما يكون SCHEDULER_MODE=interval
POST_INTERVAL_SECONDS=1800

# أوقات الذروة المحددة للنشر (يتم تفعيل هذا فقط عندما يكون SCHEDULER_MODE=peak_hours)
TIMEZONE_OFFSET=1
PEAK_HOURS=08:00,09:30,11:00,13:00,14:30,16:00,18:00,20:00,21:30,23:00

# تفعيل التباعد العشوائي لمنع الملاحظة التلقائية (True لتفعيله، False لإلغائه)
USE_JITTER=True

# أقصى تفاوت عشوائي بالثواني (مثال: 180 ثانية تعادل 3 دقائق كحد أقصى للحفاظ على النشر كل نصف ساعة تقريباً)
JITTER_MAX_SECONDS=180

# 5. إعدادات بوت التحكم بالتلغرام (Telegram Bot Control Settings)
# توكن البوت الذي تحصل عليه من BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# معرف حسابك الشخصي على تلغرام لتأمين الوصول للبوت ومنع غير المصرح لهم
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 6. إعدادات اختيار مزود الذكاء الاصطناعي والتبديل (AI Provider Switching)
# المزود الافتراضي النشط للنشر (القيم المتاحة: gemini, groq, grok)
ACTIVE_PROVIDER=gemini

# مفتاح الوصول لجوجل جيميناي (مجاني وجودة كتابة فائقة)
# يمكن الحصول عليه من: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# 7. رابط خادم التحليل (Trading Bot Worker URL)
TRADING_BOT_URL=https://worker-production-7b39.up.railway.app

