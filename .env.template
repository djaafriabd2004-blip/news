# مفاتيح الوصول والرموز السرية للمشروع
# قم بنسخ هذا الملف وتسميته .env وتعبئة البيانات المطلوبة

# 1. مفتاح منصة بينانس سكوير (Binance Square OpenAPI Key)
BINANCE_SQUARE_API_KEY=your_binance_square_api_key_here

# 2. مفتاح الوصول لـ Groq Cloud API Key
GROQ_API_KEY=your_groq_api_key_here

# 3. اسم نموذج Groq المراد استخدامه (Groq Model Name)
GROQ_MODEL=llama-3.3-70b-versatile

# 4. إعدادات جدولة الاستضافة والتباعد (Hosting Scheduler Settings)
# الفاصل الزمني بالثواني بين كل منشور (8640 ثانية تعادل 2.4 ساعة، أي 10 منشورات يومياً)
POST_INTERVAL_SECONDS=8640

# تفعيل التباعد العشوائي البشري (True لتفعيله، False لإلغائه)
# يمنع النشر في نفس الدقيقة بدقة في كل مرة لجعل الحساب يبدو طبيعياً وغير آلي
USE_JITTER=True

# أقصى تفاوت عشوائي بالثواني (مثال: 900 ثانية تعادل 15 دقيقة زيادة أو نقصاناً)
JITTER_MAX_SECONDS=900
